generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FightStatus {
  OPEN
  CLOSED
  RESOLVING
  FINISHED_RED
  FINISHED_GREEN
  FINISHED_DRAW
  CANCELED
}

enum OrderStatus {
  OPEN
  PARTIALLY_MATCHED
  MATCHED
  SETTLED
  CANCELED
}

enum LedgerEntryType {
  DEPOSIT_APPROVED
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_COMPLETED
  BET_STAKE_FROZEN
  BET_STAKE_RELEASED
  WINNING_PAYOUT
  HOUSE_BROKERAGE_FEE
  HOUSE_SPREAD_PROFIT
}

enum BetSide {
  RED
  GREEN
}

enum UserRole {
  BETTOR
  ADMIN
  HOUSE
}

model User {
  id            String   @id @default(uuid())
  phone         String
  full_name     String
  password_hash String
  role          UserRole @default(BETTOR)
  created_at    DateTime @default(now())

  wallet        Wallet?
  bet_orders    BetOrder[]

  @@map("users")
}

model Wallet {
  id                String   @id @default(uuid())
  user_id           String?  @unique // Nullable for HOUSE_WALLET
  balance_available Decimal
  balance_frozen    Decimal
  updated_at        DateTime @updatedAt

  user              User?    @relation(fields: [user_id], references: [id])
  ledger_entries    LedgerEntry[]

  @@map("wallets")
}

model LedgerEntry {
  id             String          @id @default(uuid())
  wallet_id      String
  type           LedgerEntryType
  amount         Decimal
  reference_type String
  reference_id   String
  created_at     DateTime        @default(now())

  wallet         Wallet          @relation(fields: [wallet_id], references: [id])

  @@map("ledger_entries")
}

model Fight {
  id                   String      @id @default(uuid())
  red_party_name       String
  green_party_name     String
  status               FightStatus @default(OPEN)
  resolving_expires_at DateTime?
  created_at           DateTime    @default(now())

  bet_orders           BetOrder[]
  bet_matches          BetMatch[]

  @@map("fights")
}

model BetOrder {
  id                      String      @id @default(uuid())
  user_id                 String
  fight_id                String
  side                    BetSide
  amount_staked           Decimal
  target_win_amount       Decimal
  unmatched_staked_amount Decimal
  status                  OrderStatus
  expires_at              DateTime
  created_at              DateTime    @default(now())

  user                    User        @relation(fields: [user_id], references: [id])
  fight                   Fight       @relation(fields: [fight_id], references: [id])
  bet_match_legs          BetMatchLeg[]

  @@map("bet_orders")
}

model BetMatch {
  id                 String   @id @default(uuid())
  fight_id           String
  total_red_staked   Decimal
  total_green_staked Decimal
  created_at         DateTime @default(now())

  fight              Fight    @relation(fields: [fight_id], references: [id])
  bet_match_legs     BetMatchLeg[]

  @@map("bet_matches")
}

model BetMatchLeg {
  id                        String   @id @default(uuid())
  bet_match_id              String
  bet_order_id              String
  side                      BetSide
  amount_staked_contributed Decimal
  target_win_contributed    Decimal

  bet_match                 BetMatch @relation(fields: [bet_match_id], references: [id])
  bet_order                 BetOrder @relation(fields: [bet_order_id], references: [id])

  @@map("bet_match_legs")
}

model OtpCode {
  id         String   @id @default(uuid())
  phone      String
  code       String
  is_used    Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("otp_codes")
}
